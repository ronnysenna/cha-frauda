# 🔐 Variáveis de Ambiente - Exemplo
# Copie este arquivo para .env e preencha com seus valores

# ===== BANCO DE DADOS =====
# Local (desenvolvimento)
DATABASE_URL=postgres://chafrauda:Ideal2015net@localhost:5432/chafrauda?sslmode=disable

# Remote (produção na IZPN)
# DATABASE_URL=postgres://chafrauda:Ideal2015net@easypanel.ronnysenna.com.br:5420/chafrauda?sslmode=disable

# Com Docker Compose
# DATABASE_URL=postgres://chafrauda:Ideal2015net@postgres:5432/chafrauda?sslmode=disable

# ===== SERVIDOR =====
PORT=3000
NODE_ENV=development
# NODE_ENV=production

# ===== CORS =====
CORS_ORIGIN=*
# Para produção com domínio específico:
# CORS_ORIGIN=https://seudominio.com.br

# ===== LOGGING =====
LOG_LEVEL=debug
# LOG_LEVEL=info
